generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

enum VehicleAvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
}

enum DeliveryJobType {
  DELIVERY
  PICKUP
}

enum DeliveryJobStatus {
  SCHEDULED
  EN_ROUTE
  ARRIVED
  COMPLETED
  CANCELLED
}

enum WebhookProvider {
  STRIPE
  RAZORPAY
}

enum WebhookLogStatus {
  RECEIVED
  PROCESSED
  FAILED
  DUPLICATE
  IGNORED
}

enum WebhookRetryStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ReturnRequestStatus {
  INITIATED
  APPROVED_BY_CUSTOMER
  PENDING_VENDOR_INSPECTION
  VENDOR_INSPECTED
  SETTLED
  CANCELLED
}

enum InspectionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DISPUTED
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String?         @unique
  phone         String?
  passwordHash  String?
  role          UserRole        @default(CUSTOMER)
  isNri         Boolean         @default(false)
  timezone      String          @default("Asia/Kolkata")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  bookings      Booking[]
  otpCodes      OtpCode[]
  documents     UserDocument[]
  managedVendor Vendor?
}

model UserDocument {
  id         String   @id @default(cuid())
  userId     String
  type       String
  fileUrl    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model City {
  id          String    @id @default(cuid())
  name        String    @unique
  airportName String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  vehicles    Vehicle[]

  // Performance index
  @@index([isActive, name])
}

model Vendor {
  id             String    @id @default(cuid())
  businessName   String
  contactPhone   String
  commissionRate Decimal   @db.Decimal(5, 2)
  ownerUserId    String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  vehicles       Vehicle[]
  ownerUser      User?     @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
}

model Vehicle {
  id             String    @id @default(cuid())
  title          String
  type           String
  fuel           String
  transmission   String
  seats          Int
  pricePerDayINR Int
  airportPickup  Boolean   @default(false)
  operationalStatus VehicleAvailabilityStatus @default(AVAILABLE)
  cityId         String
  vendorId       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  city           City      @relation(fields: [cityId], references: [id], onDelete: Restrict)
  vendor         Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  bookings       Booking[]

  // Performance indexes
  @@index([cityId])
  @@index([vendorId])
}

model Booking {
  id             String        @id @default(cuid())
  userId         String
  vehicleId      String
  cityName       String
  startDate      DateTime
  endDate        DateTime
  totalAmountINR Int
  currency       String        @default("INR")
  timezone       String        @default("Asia/Kolkata")
  status         BookingStatus @default(CONFIRMED)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  vehicle        Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  payments       Payment[]
  deliveryJobs   DeliveryJob[]
  alertLogs      BookingAlertLog[]
  returnRequest  ReturnRequest?
  vendorInspection VendorInspection?
  damageCharges  DamageCharge[]
  rentalSettlement RentalSettlement?

  // Performance indexes
  @@index([vehicleId, status, endDate])
  @@index([userId, status])
}
model Driver {
  id            String       @id @default(cuid())
  name          String
  phone         String?
  active        Boolean      @default(true)
  currentLat    Float?
  currentLng    Float?
  lastActiveAt  DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deliveryJobs  DeliveryJob[]
}

model DeliveryJob {
  id              String            @id @default(cuid())
  bookingId       String
  type            DeliveryJobType
  status          DeliveryJobStatus @default(SCHEDULED)
  scheduledAt     DateTime?
  assignedDriverId String?
  startLat        Float?
  startLng        Float?
  endLat          Float?
  endLng          Float?
  liveLat         Float?
  liveLng         Float?
  lastLocationAt  DateTime?
  otpHash         String?
  otpSalt         String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  booking         Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  assignedDriver  Driver?           @relation(fields: [assignedDriverId], references: [id], onDelete: SetNull)
  events          DeliveryEvent[]

  @@index([bookingId])
  @@index([status])
}

model DeliveryEvent {
  id        String            @id @default(cuid())
  jobId     String
  status    DeliveryJobStatus
  message   String?
  createdBy String?
  createdAt DateTime          @default(now())
  job       DeliveryJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String
  provider          String
  providerPaymentId String?
  amountINR         Int
  currency          String
  status            PaymentStatus @default(CREATED)
  metadataJson      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id         String   @id @default(cuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebhookEventLog {
  id               String           @id @default(cuid())
  provider         WebhookProvider
  eventId          String
  eventType        String
  providerEntityId String?
  rawPayload       String
  headersJson      String?
  status           WebhookLogStatus @default(RECEIVED)
  errorMessage     String?
  processedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([provider, eventId])
}

model WebhookRetryJob {
  id               String            @id @default(cuid())
  provider         WebhookProvider
  eventId          String
  eventType        String
  providerEntityId String?
  targetStatus     PaymentStatus?
  payloadJson      String
  status           WebhookRetryStatus @default(PENDING)
  attemptCount     Int               @default(0)
  maxAttempts      Int               @default(5)
  nextRunAt        DateTime          @default(now())
  lastError        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status, nextRunAt])
}

model ReturnRequest {
  id                String              @id @default(cuid())
  bookingId         String              @unique
  status            ReturnRequestStatus @default(INITIATED)
  initiatedAt       DateTime            @default(now())
  approvedAt        DateTime?
  approvalNotes     String?
  cancelledAt       DateTime?
  cancellationReason String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  booking           Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model VendorInspection {
  id                String               @id @default(cuid())
  bookingId         String               @unique
  status            InspectionStatus    @default(PENDING)
  fuelLevel         Int?
  odometerReading   Int?
  bodyCondition     String?
  engineCondition   String?
  tiresCondition    String?
  interiorCondition String?
  damagePhotos      String?
  inspectorName     String?
  notes             String?
  inspectAt         DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  booking           Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model DamageCharge {
  id                String   @id @default(cuid())
  bookingId         String
  chargeType        String
  description       String
  severityLevel     String
  estimatedAmount   Int
  approvedAmount    Int?
  isApproved        Boolean  @default(false)
  approvedBy        String?
  approvalNotes     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model RentalSettlement {
  id                  String   @id @default(cuid())
  bookingId           String   @unique
  originalAmount      Int
  remainingDays       Int?
  totalDamageCharges  Int      @default(0)
  lateFeeCharges      Int      @default(0)
  otherCharges        Int      @default(0)
  totalDeductions     Int      @default(0)
  refundAmount        Int      @default(0)
  settlementStatus    String   @default("PENDING")
  settlementNotes     String?
  settledAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  booking             Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model BookingAlertLog {
  id          String   @id @default(cuid())
  bookingId   String
  alertType   String
  message     String
  sentAt      DateTime @default(now())
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([alertType])
}